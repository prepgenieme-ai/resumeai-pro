# ResumeAI Pro - Environment Variables
# Add these in Vercel Dashboard → Project → Settings → Environment Variables

# ✅ REQUIRED: Your Anthropic API Key (for AI resume optimisation)
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ✅ REQUIRED: Your Razorpay Live Key ID (for payments)
# Get it from: Razorpay Dashboard → Settings → API Keys
# Starts with: rzp_live_XXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_key_here
